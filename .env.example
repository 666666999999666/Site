# 数据库连接（本地开发用）
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/blog?schema=public"

# 种子数据密码（首次初始化数据库时必须设置）
SEED_PASSWORD="your-secure-password"

# 会话密钥（32 位以上随机字符串）
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# 站点配置
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# GitHub 链接
NEXT_PUBLIC_GITHUB_URL="https://github.com/666666999999666"

# ========== 生产部署变量（腾讯云服务器 .env）==========
# DB_NAME=blog
# DB_USER=blog
# DB_PASSWORD=<强密码>
# SESSION_SECRET=<32位以上随机串>
# NEXT_PUBLIC_SITE_URL=https://你的域名
# NEXT_PUBLIC_GITHUB_URL=https://github.com/666666999999666
# SEED_PASSWORD=<初始管理员密码>
